# AI provider — OpenAI-compatible. Point OPENAI_BASE_URL at the gateway that
# serves the models below (the model IDs are passed through as plain strings).
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Model by tier. Free/default users get OPENAI_MODEL; Pro users get
# OPENAI_MODEL_PRO. If OPENAI_MODEL_PRO is unset, Pro falls back to OPENAI_MODEL.
OPENAI_MODEL=claude-haiku-4-5
OPENAI_MODEL_PRO=claude-sonnet-5

# PostHog analytics (client + server). Names only here — real values live in
# .env.local (gitignored) and must also be set in Vercel prod, or analytics
# stays dark in production.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Supabase. URL + anon key are public (shipped to the browser); the service role
# key is server-only and bypasses RLS — never expose it to the client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe. Both are server-only secrets.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (transactional email) — send-only restricted key
RESEND_API_KEY=

# Digest cron auth (Vercel sends this as Bearer; generate a long random string)
CRON_SECRET=

# HMAC secret for email unsubscribe links (long random string)
EMAIL_UNSUB_SECRET=

# Canonical site origin used in emails/redirects (e.g. https://samehere.dev)
NEXT_PUBLIC_SITE_URL=

# "true" enables Stripe checkout on /pro (anything else shows waitlist)
NEXT_PUBLIC_BILLING_ENABLED=

# Stripe price IDs (fall back to hardcoded defaults in pro/actions.ts)
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_SEMESTER=

# Eve club-host bot (normal auth user + officer memberships). Names only —
# create the user via signup, add as officer, set real values in Vercel.
EVE_BOT_EMAIL=
EVE_BOT_PASSWORD=

# "1" = signups require a valid member invite code (private beta). Unset/other = open signup.
INVITE_ONLY=
