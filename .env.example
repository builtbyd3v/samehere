# AI provider — OpenAI-compatible. Point OPENAI_BASE_URL at the gateway that
# serves the models below (the model IDs are passed through as plain strings).
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Model by tier. Free/default users get OPENAI_MODEL; Pro users get
# OPENAI_MODEL_PRO. If OPENAI_MODEL_PRO is unset, Pro falls back to OPENAI_MODEL.
OPENAI_MODEL=claude-haiku-4-5
OPENAI_MODEL_PRO=claude-sonnet-5
